{
  "name": "evidence-act-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Workers backend for an Evidence Act 2008 (Vic) admissibility agent.",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:api",
    "dev:api": "wrangler dev",
    "dev:web": "vite --config frontend/vite.config.ts",
    "build:web": "vite build --config frontend/vite.config.ts",
    "preview:web": "vite preview --config frontend/vite.config.ts",
    "deploy": "npm run build:web && wrangler deploy",
    "d1:migrate:local": "wrangler d1 migrations apply evidence_act_agent --local",
    "d1:migrate:remote": "wrangler d1 migrations apply evidence_act_agent --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260601.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.5.0",
    "vite": "^8.1.3",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  }
}
